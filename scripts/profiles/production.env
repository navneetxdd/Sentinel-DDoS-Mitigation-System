# Sentinel integration profile: production
# Default runtime profile for end users. ML/RL stay automatic without manual flag exports.

SENTINEL_INTEGRATION_PROFILE=production
SENTINEL_PROFILE=production
SENTINEL_INTEL_FEED_ENABLED=1
SENTINEL_MODEL_EXTENSION_ENABLED=1
SENTINEL_CONTROLLER_EXTENSION_ENABLED=1
SENTINEL_SIGNATURE_FEED_ENABLED=1
SENTINEL_DATAPLANE_EXTENSION_ENABLED=1
SENTINEL_ENABLE_INTEL_FEED=1
SENTINEL_ENABLE_MODEL_EXTENSION=1
SENTINEL_ENABLE_CONTROLLER_EXTENSION=1
SENTINEL_ENABLE_SIGNATURE_FEED=1
SENTINEL_ENABLE_DATAPLANE_EXTENSION=1
SENTINEL_CONTROLLER_EXTENSION_MIN_INTERVAL_MS=2000
