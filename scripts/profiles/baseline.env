# Sentinel integration profile: baseline
# Safe default for rollback and known-good runtime.

SENTINEL_INTEGRATION_PROFILE=baseline
SENTINEL_ENABLE_INTEL_FEED=0
SENTINEL_ENABLE_MODEL_EXTENSION=0
SENTINEL_ENABLE_CONTROLLER_EXTENSION=0
SENTINEL_ENABLE_SIGNATURE_FEED=0
SENTINEL_ENABLE_DATAPLANE_EXTENSION=0
SENTINEL_CONTROLLER_EXTENSION_MIN_INTERVAL_MS=2000
