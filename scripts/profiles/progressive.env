# Sentinel integration profile: progressive
# Enable module-by-module during staged validation.

SENTINEL_INTEGRATION_PROFILE=progressive
SENTINEL_PROFILE=progressive
SENTINEL_INTEL_FEED_ENABLED=1
SENTINEL_MODEL_EXTENSION_ENABLED=1
SENTINEL_CONTROLLER_EXTENSION_ENABLED=0
SENTINEL_SIGNATURE_FEED_ENABLED=1
SENTINEL_DATAPLANE_EXTENSION_ENABLED=0
SENTINEL_ENABLE_INTEL_FEED=1
SENTINEL_ENABLE_MODEL_EXTENSION=1
SENTINEL_ENABLE_CONTROLLER_EXTENSION=0
SENTINEL_ENABLE_SIGNATURE_FEED=1
SENTINEL_ENABLE_DATAPLANE_EXTENSION=0
SENTINEL_CONTROLLER_EXTENSION_MIN_INTERVAL_MS=2000

# Optional: enable Decision Engine dashboard simulation (WS commands + telemetry overlay only; no kernel/dataplane changes).
# SENTINEL_ALLOW_SIM_COMMANDS=1
