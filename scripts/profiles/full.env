# Sentinel integration profile: full
# Enable all integration modules after quality gates are green.

SENTINEL_INTEGRATION_PROFILE=full
SENTINEL_ENABLE_INTEL_FEED=1
SENTINEL_ENABLE_MODEL_EXTENSION=1
SENTINEL_ENABLE_CONTROLLER_EXTENSION=1
SENTINEL_ENABLE_SIGNATURE_FEED=1
SENTINEL_ENABLE_DATAPLANE_EXTENSION=1
SENTINEL_CONTROLLER_EXTENSION_MIN_INTERVAL_MS=2000
