# =============================================================================
# Sentinel — environment variable reference
#
# Copy this file to `.env` (for the Python backend) and `frontend/.env.local`
# (for the Vite frontend) and fill in the values for your deployment.
# Never commit the actual .env files to source control.
# =============================================================================


# -----------------------------------------------------------------------------
# Python backend  (explain_api.py)
# -----------------------------------------------------------------------------

# Required: Gemini API key for the AI Analyst endpoint (/analyze).
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: require reverse-proxy auth headers on all non-health explain API
# endpoints. Keep disabled for local development. Enable in production only
# when the API is bound to loopback behind NGINX/oauth2-proxy.
SENTINEL_REQUIRE_PROXY_AUTH=false
SENTINEL_TRUSTED_PROXY_IPS=127.0.0.1,::1
SENTINEL_PROXY_LOGIN_URL=/oauth2/start


# -----------------------------------------------------------------------------
# Vite frontend  (frontend/.env.local)
# All VITE_* variables are bundled into the client-side build — never put
# secrets here.
# -----------------------------------------------------------------------------

# URL of the running explain_api.py server.
# If left blank the frontend will gracefully skip Gemini / SHAP features.
# Default when running locally: http://localhost:5001
VITE_EXPLAIN_API_URL=http://localhost:5001

# WebSocket URL for the C pipeline (sentinel_pipeline / websocket_server).
# Default when running locally: ws://localhost:8765
# If left blank the hook falls back to ws://<page-hostname>:8765.
VITE_WS_URL=ws://localhost:8765

# Optional: enable frontend route protection backed by the explain API /session
# endpoint and reverse-proxy headers. Leave disabled for local development.
VITE_REQUIRE_AUTH=false
VITE_AUTH_SESSION_URL=
VITE_LOGIN_URL=/oauth2/start
